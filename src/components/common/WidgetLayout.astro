---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";

interface Props {
	id: string;
	name?: string;
	isCollapsed?: boolean;
	collapsedHeight?: string;
	useExpandedButtonSpacing?: boolean;
	class?: string;
	style?: string;
}
const {
	id,
	name,
	isCollapsed,
	collapsedHeight,
	useExpandedButtonSpacing = false,
	style,
} = Astro.props;
const className = Astro.props.class;
---
<widget-layout
    data-id={id}
    data-is-collapsed={String(isCollapsed)}
    data-use-expanded-button-spacing={String(useExpandedButtonSpacing)}
    class={"pb-4 card-base " + className}
    style={style}
>
    {name && (
        <div class="widget-title font-bold transition text-lg text-neutral-900 dark:text-neutral-100 relative ml-8 mt-4 mb-2
            before:w-1 before:h-4 before:rounded-md before:bg-(--primary)
            before:absolute before:left-[-16px] before:top-[5.5px] flex items-center justify-between">
            <span class="widget-name">{name}</span>
            <slot name="title-icon" />
        </div>
    )}
    <div id={id} class:list={["collapse-wrapper px-4 overflow-hidden", {"collapsed": isCollapsed, "pt-4": !name}]}>
        <slot></slot>
    </div>
    {isCollapsed && <div class="expand-btn px-4 -mb-2">
        <button
            class="btn-plain rounded-lg w-full h-9"
            title={i18n(I18nKey.more)}
            aria-label={i18n(I18nKey.more)}
            data-show-more={i18n(I18nKey.more)}
            data-show-less={i18n(I18nKey.collapse)}
            data-expanded="false"
        >
            <div class="text-(--primary) flex items-center justify-center gap-2 -translate-x-2">
                <Icon name="material-symbols:more-horiz" class="toggle-icon-more text-[1.75rem]" aria-hidden="true"></Icon>
                <Icon name="material-symbols:keyboard-arrow-up-rounded" class="toggle-icon-less hidden text-[1.75rem]" aria-hidden="true"></Icon>
                <span class="toggle-text">{i18n(I18nKey.more)}</span>
            </div>
        </button>
    </div>}
</widget-layout>

<style define:vars={{ collapsedHeight }}>
    .collapsed {
        height: var(--collapsedHeight);
    }

    widget-layout[data-is-collapsed="true"][data-expanded="true"][data-use-expanded-button-spacing="true"] .expand-btn {
        padding-top: 0.5rem;
    }
</style>

<script>
    class WidgetLayout extends HTMLElement {
        constructor() {
            super();

            if (this.dataset.isCollapsed !== "true")
                return;

            this.dataset.expanded = 'false';

            const id = this.dataset.id;
            const btn = this.querySelector('.expand-btn button') as HTMLButtonElement | null;
            const wrapper = this.querySelector(`#${id}`)

            if (!btn || !wrapper)
                return;

            const text = btn.querySelector('.toggle-text');
            const moreIcon = btn.querySelector('.toggle-icon-more');
            const lessIcon = btn.querySelector('.toggle-icon-less');
            const updateButtonState = (expanded: boolean) => {
                const label = expanded
                    ? btn.dataset.showLess || ''
                    : btn.dataset.showMore || '';

                btn.dataset.expanded = String(expanded);
                this.dataset.expanded = String(expanded);
                btn.title = label;
                btn.setAttribute('aria-label', label);
                if (text)
                    text.textContent = label;
                moreIcon?.classList.toggle('hidden', expanded);
                lessIcon?.classList.toggle('hidden', !expanded);
            };

            btn.addEventListener('click', () => {
                const expanded = btn.dataset.expanded === 'true';
                wrapper.classList.toggle('collapsed', expanded);
                updateButtonState(!expanded);
            });
        }
    }

    if (!customElements.get("widget-layout")) {
        customElements.define("widget-layout", WidgetLayout);
    }
</script>
